{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:best-practices",
    "group:jsUnitTest",
    "group:vite",
    "helpers:pinGitHubActionDigestsToSemver",
    "security:openssf-scorecard",
    ":approveMajorUpdates",
    ":enableVulnerabilityAlerts",
    ":pinAllExceptPeerDependencies"
  ],
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": ["/(^|/)prettier.config.js$/"],
      "depNameTemplate": "typescript",
      "datasourceTemplate": "npm",
      "matchStrings": [
        "\\/\\/ renovate: datasource=(?<datasource>[a-zA-Z0-9-._]+?) depName=(?<depName>[^\\s]+?)(?: (?:lookupName|packageName)=(?<packageName>[^\\s]+?))?(?: versioning=(?<versioning>[^\\s]+?))?(?: extractVersion=(?<extractVersion>[^\\s]+?))?\\s+importOrderTypeScriptVersion\\s*\\:\\s*[\"']?(?<currentValue>.+?)[\"']"
      ]
    }
  ],
  "registryAliases": {
    "dhi.io": "dhi.io"
  },
  "hostRules": [
    {
      "matchHost": "dhi.io",
      "hostType": "docker",
      "username": "{{ secrets.MEND_DOCKER_HUB_USERNAME }}",
      "password": "{{ secrets.MEND_DOCKER_HUB_PASSWORD }}"
    }
  ],
  "packageRules": [
    {
      "description": "Apply minimum release age to all relevant datasources with timestamps",
      "internalChecksFilter": "strict",
      "matchDatasources": [
        "github-releases",
        "github-tags",
        "node-version",
        "npm"
      ],
      "minimumReleaseAge": "3 days"
    },
    {
      "description": "Apply minimum release age to docker datasource regardless of timestamps",
      "internalChecksFilter": "strict",
      "matchDatasources": ["docker"],
      "minimumReleaseAge": "3 days",
      "minimumReleaseAgeBehaviour": "timestamp-optional"
    },
    {
      "extends": ["packages:eslint"],
      "groupName": "eslint packages"
    },
    {
      "groupName": "prettier packages",
      "matchPackageNames": ["prettier**", "@ianvs/prettier-plugin-sort-imports"]
    },
    {
      "extends": ["packages:react"],
      "groupName": "react packages"
    },
    {
      "extends": ["packages:stylelint"],
      "groupName": "stylelint packages"
    },
    {
      "groupName": "playwright monorepo",
      "matchPackageNames": [
        "playwright",
        "@playwright/test",
        "mcr.microsoft.com/playwright",
        "gwennlbh/playwright-bun"
      ]
    },
    {
      "groupName": "storybook monorepo",
      "matchPackageNames": [
        "@storybook/**",
        "eslint-plugin-storybook",
        "storybook"
      ]
    },
    {
      "groupName": "bun monorepo",
      "matchPackageNames": ["bun", "@types/bun", "bun-types", "oven/bun"]
    }
  ],
  "patch": {
    "rebaseWhen": "behind-base-branch"
  },
  "rebaseWhen": "conflicted",
  "osvVulnerabilityAlerts": true
}
